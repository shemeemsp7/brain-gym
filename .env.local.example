# Database
DATABASE_URL=postgres://postgres:root@localhost:5432/ascendarium

# NextAuth
NEXTAUTH_SECRET=replace-with-a-random-string   # generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Portkey gateway
PORTKEY_BASE_URL=https://api.portkey.ai/v1
PORTKEY_API_KEY=
# Model routed through Portkey (@<provider-slug>/<model-id>)
PORTKEY_MODEL=

# Google OAuth (optional - leave blank to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional - leave blank to disable GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Verbose server-side logging (do not enable in production - debug logs include sensitive data)
DEBUG=false
